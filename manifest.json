{
    "manifest_version": 3,
    "name": "Gemini Resizer",
    "version": "1.0.0",
    "description": "Adjust the width of the chat area on gemini.google.com",
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://gemini.google.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "tabs"
    ]
}
