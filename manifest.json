{
    "manifest_version": 3,
    "short_name": "Gemini Resizer",
    "name": "Gemini Resizer: Adjust Gemini Chat Width",
    "version": "1.0.0",
    "description": "Adjust the width of chat area on Google Gemini desktop website for a more comfortable experience.",
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["https://gemini.google.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "tabs"
    ]
}
